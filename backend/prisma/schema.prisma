// Prisma schema for the Restaurant Management System

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------
// Enums
// ------------------------------

enum Role {
  ADMIN
  MANAGER
  CASHIER
  EMPLOYEE
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  TERMINATED
}

enum PaymentType {
  SALARY
  BONUS
  ADVANCE
  OVERTIME
  DEDUCTION
}

enum PurchasePaymentStatus {
  PAID
  UNPAID
  PARTIAL
}

enum PaymentMethod {
  CASH
  CARD
  MOBILE
  ONLINE
}

// ------------------------------
// Models
// ------------------------------

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  email     String   @unique
  password  String
  role      Role     @default(EMPLOYEE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sales    Sale[]
  expenses Expense[] @relation("ExpenseCreatedBy")

  @@map("users")
}

model Employee {
  id        Int            @id @default(autoincrement())
  fullName  String
  phone     String?
  address   String?
  position  String
  salary    Float
  startDate DateTime       @default(now())
  status    EmployeeStatus @default(ACTIVE)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  payments EmployeePayment[]

  @@map("employees")
}

model EmployeePayment {
  id          Int         @id @default(autoincrement())
  employeeId  Int
  employee    Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  amount      Float
  paymentType PaymentType
  paymentDate DateTime    @default(now())
  month       String
  notes       String?
  createdAt   DateTime    @default(now())

  @@index([employeeId])
  @@map("employee_payments")
}

model Supplier {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String?
  email     String?
  address   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stockItems StockItem[]
  purchases  Purchase[]

  @@map("suppliers")
}

model StockItem {
  id              Int       @id @default(autoincrement())
  name            String
  category        String
  quantity        Float     @default(0)
  unit            String
  buyingPrice     Float     @default(0)
  minimumQuantity Float     @default(0)
  expirationDate  DateTime?
  supplierId      Int?
  supplier        Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  purchaseItems   PurchaseItem[]
  menuIngredients MenuItemIngredient[]

  @@index([supplierId])
  @@map("stock_items")
}

model Purchase {
  id            Int                   @id @default(autoincrement())
  supplierId    Int
  supplier      Supplier              @relation(fields: [supplierId], references: [id])
  totalAmount   Float                 @default(0)
  paymentStatus PurchasePaymentStatus @default(UNPAID)
  purchaseDate  DateTime              @default(now())
  createdAt     DateTime              @default(now())

  items PurchaseItem[]

  @@index([supplierId])
  @@map("purchases")
}

model PurchaseItem {
  id          Int       @id @default(autoincrement())
  purchaseId  Int
  purchase    Purchase  @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  stockItemId Int
  stockItem   StockItem @relation(fields: [stockItemId], references: [id])
  quantity    Float
  unitPrice   Float
  totalPrice  Float

  @@index([purchaseId])
  @@index([stockItemId])
  @@map("purchase_items")
}

model MenuItem {
  id           Int      @id @default(autoincrement())
  name         String
  category     String
  sellingPrice Float
  costPrice    Float    @default(0)
  description  String?
  isAvailable  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ingredients MenuItemIngredient[]
  saleItems   SaleItem[]

  @@map("menu_items")
}

model MenuItemIngredient {
  id           Int       @id @default(autoincrement())
  menuItemId   Int
  menuItem     MenuItem  @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  stockItemId  Int
  stockItem    StockItem @relation(fields: [stockItemId], references: [id])
  quantityUsed Float
  unit         String

  @@unique([menuItemId, stockItemId])
  @@index([stockItemId])
  @@map("menu_item_ingredients")
}

model Sale {
  id            Int           @id @default(autoincrement())
  userId        Int
  user          User          @relation(fields: [userId], references: [id])
  totalAmount   Float         @default(0)
  discount      Float         @default(0)
  paymentMethod PaymentMethod @default(CASH)
  isPaid        Boolean       @default(false)
  saleDate      DateTime      @default(now())
  createdAt     DateTime      @default(now())

  items SaleItem[]

  @@index([userId])
  @@map("sales")
}

model SaleItem {
  id         Int      @id @default(autoincrement())
  saleId     Int
  sale       Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  menuItemId Int
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  quantity   Int
  unitPrice  Float
  totalPrice Float

  @@index([saleId])
  @@index([menuItemId])
  @@map("sale_items")
}

model Expense {
  id            Int           @id @default(autoincrement())
  name          String
  category      String
  amount        Float
  paymentMethod PaymentMethod @default(CASH)
  expenseDate   DateTime      @default(now())
  description   String?
  createdBy     Int?
  creator       User?         @relation("ExpenseCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  createdAt     DateTime      @default(now())

  @@index([createdBy])
  @@map("expenses")
}
